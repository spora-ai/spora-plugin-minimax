# Baseline ignores 16 expected class/method-notFound errors for Spora\Services\MediaArchive\* — resolves when spora-ai/spora-core#125 lands and a new spora-core release is consumed. Regenerate with `vendor/bin/phpstan analyse --generate-baseline` after the dep bump.
parameters:
	ignoreErrors:
		-
			message: '#^Call to an undefined method Spora\\Plugins\\MiniMax\\Tools\\MiniMaxImageTool\:\:mediaArchive\(\)\.$#'
			identifier: method.notFound
			count: 1
			path: src/Tools/MiniMaxImageTool.php

		-
			message: '#^Call to an undefined method Spora\\Plugins\\MiniMax\\Tools\\MiniMaxImageTool\:\:setMediaArchive\(\)\.$#'
			identifier: method.notFound
			count: 1
			path: src/Tools/MiniMaxImageTool.php

