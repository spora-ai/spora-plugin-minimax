<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         cacheDirectory=".phpunit.cache"
>
    <testsuites>
        <testsuite name="Unit">
            <directory suffix="Test.php">./tests/Unit</directory>
        </testsuite>
    </testsuites>

    <!-- Coverage scope. PHPUnit 12 / Pest 4 only generate a clover report when
         the suite knows which source files to measure. Without this block,
         pcov runs but no coverage data is collected and Pest exits 1. -->
    <source>
        <include>
            <directory>src</directory>
        </include>
    </source>
</phpunit>
